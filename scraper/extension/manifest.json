{
  "manifest_version": 3,
  "name": "Jarvis Atrix Sync",
  "version": "1.0",
  "description": "Sincroniza substatus do Atrix no painel Jarvis a cada 30 min",
  "permissions": ["alarms", "tabs", "storage", "scripting", "notifications"],
  "host_permissions": [
    "https://atrix.mobtelecom.com.br/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Jarvis Atrix Sync"
  }
}
