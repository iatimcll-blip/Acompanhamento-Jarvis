# ── Credenciais Atrix ──────────────────────────────────────────────────────
ATRIX_BASE_URL=https://atrix.mobtelecom.com.br/controle/
ATRIX_USER=seu_usuario_aqui
ATRIX_PASS=sua_senha_aqui

# Seletor CSS do dropdown de substatus (deixe vazio para detecção automática)
# Exemplo após inspecionar: ATRIX_SUBSTATUS_SELECTOR=select#substatus
ATRIX_SUBSTATUS_SELECTOR=

# ── GitHub ─────────────────────────────────────────────────────────────────
GITHUB_TOKEN=seu_token_github_aqui
GITHUB_REPO=iatimcll-blip/Acompanhamento-Jarvis
GITHUB_BRANCH=main

# ── Comportamento ──────────────────────────────────────────────────────────
# Intervalo entre ciclos (minutos)
INTERVAL_MINUTES=90

# Pausa entre chamados (segundos) — evita sobrecarga no Atrix
DELAY_SECONDS=2

# Modo debug: abre browser visível + salva screenshots (1=ativo, 0=desativado)
DEBUG=0
